# Default behavior uses MockProvider and does not require credentials.
# Set OPENAI_API_KEY to call an OpenAI-compatible chat completions endpoint.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# For Azure deployment-style endpoints, set OPENAI_BASE_URL to:
# https://<resource>.openai.azure.com/openai/deployments/<deployment>
# For Foundry project endpoints, set OPENAI_BASE_URL to the project endpoint.
# Leave OPENAI_API_VERSION empty because /openai/v1 does not accept that query.
# https://<resource>.services.ai.azure.com/api/projects/<project>
OPENAI_API_VERSION=
